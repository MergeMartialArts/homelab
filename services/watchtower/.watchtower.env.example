# Timezone for logs and cron schedule
TZ=Europe/Berlin

# --- Monitoring & Updates ---
# Only monitor, never update containers
WATCHTOWER_MONITOR_ONLY=true
# Remove old images after updating (only relevant if MONITOR_ONLY=false)
WATCHTOWER_CLEANUP=false
# Remove anonymous volumes after updating
WATCHTOWER_REMOVE_VOLUMES=false
# Also monitor restarting containers
WATCHTOWER_INCLUDE_RESTARTING=false
# Also monitor stopped/exited containers
WATCHTOWER_INCLUDE_STOPPED=false
# Start stopped containers if their image was updated
WATCHTOWER_REVIVE_STOPPED=false
# Do not pull new images, only check local cache
WATCHTOWER_NO_PULL=false
# Do not restart containers after updating
WATCHTOWER_NO_RESTART=false
# Let container labels take precedence over arguments
WATCHTOWER_LABEL_TAKE_PRECEDENCE=false
# Only monitor containers with watchtower.enable=true label
WATCHTOWER_LABEL_ENABLE=false
# Exclude specific containers (comma-separated)
# WATCHTOWER_DISABLE_CONTAINERS=container1,container2

# --- Schedule ---
# Cron expression (6 fields). Every day at 6am:
WATCHTOWER_SCHEDULE=0 0 6 * * *
# Alternative: poll interval in seconds (don't use both)
# WATCHTOWER_POLL_INTERVAL=86400

# --- Logging ---
# Log level: panic, fatal, error, warn, info, debug, trace
WATCHTOWER_LOG_LEVEL=info
# Log format: Auto, LogFmt, Pretty, JSON
WATCHTOWER_LOG_FORMAT=Auto
# Disable ANSI colors in logs
NO_COLOR=false
# Debug mode (verbose)
WATCHTOWER_DEBUG=false
# Trace mode (very verbose, exposes credentials!)
WATCHTOWER_TRACE=false

# --- Startup ---
# Do not send a notification when watchtower starts
WATCHTOWER_NO_STARTUP_MESSAGE=true

# --- Notifications (shoutrrr syntax) ---
WATCHTOWER_NOTIFICATION_URL=smtp://

# --- Misc ---
# Timeout before forcefully stopping a container
WATCHTOWER_TIMEOUT=10s
# Warn on HEAD pull failures: always, auto, never
WATCHTOWER_WARN_ON_HEAD_FAILURE=auto