# Samba workgroup name
WORKGROUP=WORKGROUP

# Share names visible on the network
SCANNER_SHARE_NAME=paperless-scanner
PAPERLESS_SHARE_NAME=paperless

# Linux user for Samba shares.
# Derived automatically from USERMAP_UID in paperless-ngx/.env.
# Only set this to override (e.g. if the username differs from the USERMAP_UID owner).
# SHARE_USER=

# Paperless data directory
# Inherited from paperless-ngx/.env when run via setup.sh; only set here
# if running samba/setup.sh standalone with a non-default path.
# PAPERLESS_DIR=/srv/paperless
