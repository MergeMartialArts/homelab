########################################
# Docker Compose variables
########################################

# UID/GID of the host user that owns the data directories and runs the containers.
# Populated automatically from the user running setup.sh.
USERMAP_UID=
USERMAP_GID=


########################################
# Storage
########################################

PAPERLESS_DIR="${PAPERLESS_DIR:-/srv/paperless}"


########################################
# Paperless
########################################

# Generate:
# openssl rand -base64 32
PAPERLESS_SECRET_KEY=change-me

# Timezone
PAPERLESS_TIME_ZONE=Europe/Berlin

# Public URL
PAPERLESS_URL=http://localhost:8000


########################################
# OCR
########################################

PAPERLESS_OCR_LANGUAGE=deu+eng+ita+spa+fra+tha

# Additional installed OCR languages
# Requires tesseract language packages in the container
PAPERLESS_OCR_LANGUAGES=tha

# Archive format
PAPERLESS_OCR_OUTPUT_TYPE=pdfa


########################################
# Consumer
########################################

# Scan subfolders
PAPERLESS_CONSUMER_RECURSIVE=true

# Check consume folder every X seconds
PAPERLESS_CONSUMER_POLLING=30

# Delay before processing new files
PAPERLESS_CONSUMER_POLLING_DELAY=15


########################################
# Barcode support
########################################

PAPERLESS_CONSUMER_ENABLE_BARCODES=true
PAPERLESS_CONSUMER_ENABLE_ASN_BARCODE=true


########################################
# Filenames
########################################

PAPERLESS_FILENAME_FORMAT={{ owner_username }}/{{ correspondent }}/{{ created_year }}/{{ created_year }}-{{ created_month }}-{{ created_day }}_{{ title }}

PAPERLESS_FILENAME_FORMAT_REMOVE_NONE=true


########################################
# Email import (optional)
########################################

# PAPERLESS_EMAIL_HOST=imap.example.com
# PAPERLESS_EMAIL_PORT=993
# PAPERLESS_EMAIL_HOST_USER=user@example.com
# PAPERLESS_EMAIL_HOST_PASSWORD=secret
# PAPERLESS_EMAIL_FROM=user@example.com
# PAPERLESS_EMAIL_USE_TLS=true
# PAPERLESS_EMAIL_USE_SSL=false


########################################
# Accounts
########################################

# Only relevant if registration is enabled
PAPERLESS_ACCOUNT_EMAIL_VERIFICATION=false


########################################
# Logging
########################################

PAPERLESS_LOGGING_LEVEL=INFO